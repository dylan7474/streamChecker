#!/bin/sh
# configure script for streamChecker

PREFIX="/usr/local"

show_help() {
    cat <<USAGE
Usage: ./configure [options]
Options:
  --prefix=PREFIX  Install files in PREFIX [/usr/local]
  --help           Show this help text
USAGE
}

for arg in "$@"; do
    case "$arg" in
        --prefix=*) PREFIX=${arg#*=} ;;
        --help) show_help; exit 0 ;;
        *) echo "WARNING: Unknown option: $arg" ;;
    esac
done

missing_tools=""

check_tool() {
    if ! command -v "$1" >/dev/null 2>&1; then
        missing_tools="$missing_tools $1"
    fi
}

check_tool gcc
check_tool make
check_tool pkg-config

if [ -n "$missing_tools" ]; then
    echo "ERROR: Missing required build tool(s):$missing_tools"
    echo "Install hints:"
    echo "  Debian/Ubuntu : sudo apt install build-essential pkg-config"
    echo "  Fedora        : sudo dnf install gcc make pkgconf-pkg-config"
    echo "  Arch Linux    : sudo pacman -S base-devel pkgconf"
    exit 1
fi

deps="gtk+-3.0 gstreamer-1.0 libcurl json-c"
missing_deps=""

for dep in $deps; do
    if ! pkg-config --exists "$dep"; then
        missing_deps="$missing_deps $dep"
    fi
done

if [ -n "$missing_deps" ]; then
    echo "ERROR: Missing required development package(s):$missing_deps"
    echo "Install hints:"
    echo "  Debian/Ubuntu : sudo apt install libgtk-3-dev libgstreamer1.0-dev libcurl4-openssl-dev libjson-c-dev"
    echo "  Fedora        : sudo dnf install gtk3-devel gstreamer1-devel libcurl-devel json-c-devel"
    echo "  Arch Linux    : sudo pacman -S gtk3 gstreamer curl json-c"
    exit 1
fi

cat > config.mk <<CONFIG_EOF
# Auto-generated by configure
CC = gcc
CFLAGS = -Wall -O2 \$(shell pkg-config --cflags $deps)
LIBS = \$(shell pkg-config --libs $deps) -lpthread
PREFIX = $PREFIX
CONFIG_EOF

echo "Configuration complete. Run 'make' to build."
