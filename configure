#!/bin/sh
# Simple configure script for the Internet Radio Player

PREFIX="/usr/local"

# Parse arguments
for arg do
    case "$arg" in
        --prefix=*) PREFIX=${arg#*=} ;;
        --help)
            echo "Usage: ./configure [options]"
            echo "Options:"
            echo "  --prefix=PREFIX  Install architecture-independent files in PREFIX [/usr/local]"
            exit 0
            ;;
    esac
done

echo "Checking for pkg-config..."
if ! command -v pkg-config >/dev/null 2>&1; then
    echo "ERROR: pkg-config is required but not found."
    exit 1
fi

DEPS="gtk+-3.0 gstreamer-1.0 libcurl json-c"
echo "Checking for dependencies: $DEPS..."

if ! pkg-config --exists $DEPS; then
    echo "ERROR: Missing one or more required dependencies."
    echo "Please ensure GTK3, GStreamer 1.0, libcurl, and json-c development packages are installed."
    echo "(e.g., libgtk-3-dev, libgstreamer1.0-dev, libcurl4-openssl-dev, libjson-c-dev)"
    exit 1
fi

echo "Creating config.mk..."
cat > config.mk <<EOF
# Auto-generated by configure
CC = gcc
CFLAGS = -Wall -O2 \$(shell pkg-config --cflags $DEPS)
LIBS = \$(shell pkg-config --libs $DEPS) -lpthread
PREFIX = $PREFIX
EOF

echo "Configuration complete. You can now run 'make'."
